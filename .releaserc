{
  "branches": [
    "main"
  ],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "for pkg in packages/fluxformula.core packages/fluxformula packages/fluxformula.addressables packages/fluxformula.addressables.unitask; do sed -i 's/\"version\":\\s*\"[^\"]*\"/\"version\": \"${nextRelease.version}\"/g' \"$pkg/package.json\"; done"
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": [
          "packages/fluxformula.core/package.json",
          "packages/fluxformula/package.json",
          "packages/fluxformula.addressables/package.json",
          "packages/fluxformula.addressables.unitask/package.json",
          "CHANGELOG.md"
        ],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
